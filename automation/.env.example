# ============================================
# AUTOMAÇÃO — Variáveis de Ambiente
# ============================================
# Copie para .env e preencha

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Firebase Admin SDK (JSON do service account)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=seu-projeto

# Site
SITE_URL=https://fabricadeliberdade.com.br

# Afiliados
AMAZON_TAG=fabricadeliberdade-20
MERCADOLIVRE_TAG=fabricadeliberdade
ALIEXPRESS_TAG=fabricadeliberdade
HOTMART_SRC=fabricadeliberdade

# Schedule
ARTICLES_PER_DAY=3
AUTO_PUBLISH=false
DEFAULT_LOCALE=pt-BR
